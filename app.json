{
  "expo": {
    "name": "ozdeta",
    "slug": "ozdeta6",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/derstakipicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/derstakipicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mhmt03.ozdeta"
    },
    "android": {
      "package": "com.mhmt03.ozdeta",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/derstakipicon.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "useSQLCipher": true
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "605bc39b-865a-4500-b21f-3f66398ae534"
      }
    },
    "owner": "gunnermg"
  }
}
